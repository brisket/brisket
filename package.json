{
  "name": "brisket",
  "version": "2.0.0",
  "description": "Framework for building single page web apps using isomorphic Javascript",
  "type": "module",
  "main": "lib/brisket.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "backbone": "^1.6.0",
    "backbone.nativeajax": "^0.4.3",
    "cookie": "^1.0.2",
    "express": "^5.0.1",
    "jquery": "^3.7.1",
    "jsdom": "^26.0.0",
    "qs": ">=2.3.0",
    "underscore": "^1.13.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.1",
    "@stylistic/eslint-plugin-js": "^4.1.0",
    "@types/node": "^22.13.1",
    "axios-mock-adapter": "^2.1.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "jasmine-browser-runner": "^3.0.0",
    "jasmine-core": "^5.6.0",
    "nock": "^14.0.0",
    "supertest": "^7.0.0",
    "tinybench": "^3.1.0"
  },
  "browser": {
    "./lib/server/AjaxCallsForCurrentRequest.js": false,
    "./lib/server/DomainLocalStorage.js": false,
    "./lib/server/ForwardClientRequest.js": false,
    "./lib/server/Server.js": false,
    "./lib/server/ServerAjax.js": false,
    "./lib/server/ServerDispatcher.js": false,
    "./lib/server/ServerInitializer.js": false,
    "./lib/server/ServerRenderer.js": false,
    "./lib/server/ServerRenderingWorkflow.js": false,
    "./lib/server/ServerRequest.js": false,
    "./lib/server/ServerResponse.js": false,
    "./lib/server/ServerResponseWorkflow.js": false,
    "./lib/server/serverWindow.js": false
  },
  "scripts": {
    "benchmarks": "node ./benchmarks.js",
    "lint:ci": "eslint lib/ eslint.config.js benchmarks.js testing.js benchmarks/ spec/client/ spec/helpers/ spec/support/ spec/mock/ spec/server/ demo/app/ demo/server.js demo/exampleApi.js",
    "lint": "npm run lint:ci -- --fix",
    "server-tests": "npx jasmine",
    "clean-client": "rm -rf spec/build",
    "build-client": "npm run clean-client && esbuild spec/client/**/*[sS]pec.js --bundle --outdir=spec/build --format=esm",
    "client-tests-debug": "npm run build-client && npx jasmine-browser-runner serve --port=8080",
    "client-tests": "npm run build-client && npx jasmine-browser-runner runSpecs",
    "clean-demo": "rm -rf demo/public/javascripts/*",
    "build-demo": "npm run clean-demo && esbuild demo/app/javascripts/client/initializeClient.js --bundle --outfile=demo/public/javascripts/application.js --format=esm --metafile=demo/public/javascripts/application-meta.json",
    "start-demo": "npm run build-demo && node demo/server.js",
    "e2e-tests": "npx playwright test --reporter=list",
    "e2e-tests-debug": "npx playwright test --ui",
    "test": "npm run server-tests && npm run client-tests && npm run e2e-tests"
  },
  "keywords": [
    "isomorphic",
    "javascript",
    "spa",
    "backbone"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brisket/brisket.git"
  },
  "bugs": "http://github.com/brisket/brisket/issues"
}
